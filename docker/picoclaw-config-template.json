{
  "agents": {
    "defaults": {
      "workspace": "/root/.picoclaw/workspace",
      "model": "claude-opus-4-5",
      "max_tokens": 4096,
      "temperature": 0.7,
      "max_tool_iterations": 20
    }
  },
  "providers": {
    "anthropic": {
      "api_key": "ANTHROPIC_API_KEY_PLACEHOLDER",
      "api_base": "https://api.anthropic.com"
    }
  },
  "tools": {
    "web": {
      "search": {
        "api_key": "BRAVE_API_KEY_PLACEHOLDER",
        "max_results": 5
      }
    }
  }
}
